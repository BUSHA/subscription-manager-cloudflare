    "axios": "^1.16.1",
    "currency-symbol-map": "^5.1.0",
    "date-fns": "^4.2.1",
    "framer-motion": "^12.39.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-datepicker": "^9.1.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.0",
