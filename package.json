{
  "name": "subscription-manager-cf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
    "db:create": "wrangler d1 create subscription-manager",
    "db:migrate:local": "wrangler d1 migrations apply subscription-manager --local",
    "db:migrate:remote": "wrangler d1 migrations apply subscription-manager --remote",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260521.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "wrangler": "^4.0.0"
  }
}
