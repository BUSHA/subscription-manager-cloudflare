{
  "name": "subscription-manager-cf",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "cf:dev": "wrangler dev",
    "cf:deploy": "wrangler deploy",
